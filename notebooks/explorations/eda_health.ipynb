    "---\n",
    "## 1. Introduction <a name=\"introduction\"></a>\n",
    "\n",
    "This notebook explores the **healthcare and mental health** categories in our dataset. Healthcare AI responses require particular attention to:\n",
    "- **Safety**: Medical advice must be accurate and non-harmful\n",
    "- **Empathy**: Responses should show understanding and compassion\n",
    "- **Helpfulness**: Practical, actionable guidance is critical\n",
    "- **Cultural Sensitivity**: Healthcare needs vary across communities"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# Cell 1: Import Libraries\n",
    "# ============================================\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from collections import Counter\n",
    "import re\n",
    "import json\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "\n",
    "print(\"Libraries loaded!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 2. Data Loading <a name=\"data-loading\"></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# Cell 2: Load All Datasets\n",
    "# ============================================\n",
    "DATA_DIR = '../data/raw/'\n",
    "\n",
    "train_df = pd.read_csv(f'{DATA_DIR}train.csv')\n",
    "labels_df = pd.read_csv(f'{DATA_DIR}labels.csv')\n",
    "prompts = json.load(open(f'{DATA_DIR}prompts.json'))\n",
    "responses = json.load(open(f'{DATA_DIR}responses.json'))\n",
    "\n",
    "# Merge train with labels for full annotation data\n",
    "merged_df = train_df.merge(labels_df[['id', 'safety_score', 'fairness_score', 'clarity_score', 'annotator_id']],\n",
    "                           on='id', how='left')\n",
    "\n",
    "# Filter health-related categories\n",
    "health_df = merged_df[merged_df['category'].isin(['healthcare', 'mental_health'])].copy()\n",
    "\n",
    "print(f\"Total records:         {len(train_df)}\")\n",
    "print(f\"Healthcare records:    {len(merged_df[merged_df['category'] == 'healthcare'])}\")\n",
    "print(f\"Mental health records: {len(merged_df[merged_df['category'] == 'mental_health'])}\")\n",
    "print(f\"Combined health records: {len(health_df)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# Cell 3: Feature Engineering for Health Data\n",
    "# ============================================\n",
    "def add_health_features(df):\n",
    "    df['response_word_count'] = df['response'].str.split().str.len()\n",
    "    df['has_medical_terms'] = df['response'].apply(\n",
    "        lambda x: bool(re.search(r'\\b(diagnos|treatment|symptom|therapy|medication|clinical|patient|disease|disorder)\\b',\n",
    "                                str(x).lower()))\n",
    "    )\n",
    "    df['has_empathy_words'] = df['response'].apply(\n",
    "        lambda x: bool(re.search(r'\\b(understand|support|care|compassion|important|community|together|hope)\\b',\n",
    "                                str(x).lower()))\n",
    "    )\n",
    "    df['has_numbers'] = df['response'].apply(lambda x: bool(re.search(r'\\d', str(x))))\n",
    "    df['has_list_format'] = df['response'].apply(lambda x: bool(re.search(r'(\\d\\)|-\\s|\\*)', str(x))))\n",
    "    df['exclamation_count'] = df['response'].str.count('!')\n",
    "    df['question_count'] = df['response'].str.count('\\?')\n",
    "    df['health_composite'] = (\n",
    "        df.get('humanity_score', pd.Series([0]*len(df))) * 0.25 +\n",
    "        df.get('performance_score', pd.Series([0]*len(df))) * 0.20 +\n",
    "        df.get('helpfulness_score', pd.Series([0]*len(df))) * 0.25 +\n",
    "        df.get('safety_score', pd.Series([0]*len(df))) * 0.30\n",
    "    )\n",
    "    return df\n",
    "\n",
    "health_df = add_health_features(health_df)\n",
    "all_health = add_health_features(merged_df.copy())\n",
    "\n",
    "print(\"Health features added:\")\n",
    "print(health_df[['response_word_count', 'has_medical_terms', 'has_empathy_words', 'has_list_format']].describe())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 3. Healthcare vs Mental Health Analysis <a name=\"health-analysis\"></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# Cell 4: Score Comparison - Healthcare vs Mental Health\n",
    "# ============================================\n",
    "healthcare = merged_df[merged_df['category'] == 'healthcare']\n",
    "mental = merged_df[merged_df['category'] == 'mental_health']\n",
    "\n",
    "metrics = ['humanity_score', 'performance_score', 'helpfulness_score']\n",
    "if 'safety_score' in merged_df.columns:\n",
    "    metrics.append('safety_score')\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "x = np.arange(len(metrics))\n",
    "width = 0.35\n",
    "\n",
    "bars1 = ax.bar(x - width/2, [healthcare[m].mean() for m in metrics], width,\n",
    "               label='Healthcare', color='#3498db', alpha=0.85, edgecolor='white')\n",
    "bars2 = ax.bar(x + width/2, [mental[m].mean() for m in metrics], width,\n",
    "               label='Mental Health', color='#9b59b6', alpha=0.85, edgecolor='white')\n",
    "\n",
    "ax.set_xlabel('Score Dimension', fontsize=12)\n",
    "ax.set_ylabel('Average Score', fontsize=12)\n",
    "ax.set_title('Healthcare vs Mental Health: Score Comparison', fontsize=14, fontweight='bold')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels([m.replace('_', ' ').title() for m in metrics], rotation=15)\n",
    "ax.legend(loc='best')\n",
    "ax.set_ylim(0, 5.5)\n",
    "\n",
    "for bar in bars1:\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.05,\n",
    "            f'{bar.get_height():.2f}', ha='center', va='bottom', fontsize=9)\n",
    "for bar in bars2:\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.05,\n",
    "            f'{bar.get_height():.2f}', ha='center', va='bottom', fontsize=9)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/eda_health_comparison.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
