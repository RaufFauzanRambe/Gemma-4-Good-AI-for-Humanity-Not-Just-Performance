    "---\n",
    "## 4. Sentiment & Tone Analysis <a name=\"sentiment-analysis\"></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# Cell 5: Empathy & Professionalism Detection\n",
    "# ============================================\n",
    "empathy_patterns = [\n",
    "    r'\\b(important|crucial|essential|vital)\\b',\n",
    "    r'\\b(community|communities|together|collective)\\b',\n",
    "    r'\\b(support|care|help|assist|empower)\\b',\n",
    "    r'\\b(accessible|affordable|inclusive|equitable)\\b',\n",
    "    r'\\b(understanding|awareness|compassion)\\b'\n",
    "]\n",
    "\n",
    "professionalism_patterns = [\n",
    "    r'\\b(research|study|evidence|data)\\b',\n",
    "    r'\\b(strategy|approach|framework|method)\\b',\n",
    "    r'\\b(implement|develop|establish)\\b',\n",
    "    r'\\b(outcome|impact|result|improvement)\\b'\n",
    "]\n",
    "\n",
    "def count_patterns(text, patterns):\n",
    "    return sum(len(re.findall(p, str(text).lower())) for p in patterns)\n",
    "\n",
    "health_df['empathy_score'] = health_df['response'].apply(lambda x: count_patterns(x, empathy_patterns))\n",
    "health_df['professionalism_score'] = health_df['response'].apply(lambda x: count_patterns(x, professionalism_patterns))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "scatter = ax.scatter(health_df['empathy_score'], health_df['professionalism_score'],\n",
    "                     c=health_df['humanity_score'], cmap='coolwarm', s=120, alpha=0.8,\n",
    "                     edgecolors='gray')\n",
    "ax.set_xlabel('Empathy Score (keyword-based)', fontsize=12)\n",
    "ax.set_ylabel('Professionalism Score (keyword-based)', fontsize=12)\n",
    "ax.set_title('Empathy vs Professionalism in Health Responses', fontsize=14, fontweight='bold')\n",
    "plt.colorbar(scatter, label='Humanity Score')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/eda_health_empathy.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 5. Response Quality by Difficulty <a name=\"difficulty-analysis\"></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# Cell 6: Difficulty Level Analysis\n",
    "# ============================================\n",
    "difficulty_analysis = health_df.groupby('difficulty').agg(\n",
    "    count=('id', 'count'),\n",
    "    avg_humanity=('humanity_score', 'mean'),\n",
    "    avg_performance=('performance_score', 'mean'),\n",
    "    avg_helpfulness=('helpfulness_score', 'mean'),\n",
    "    avg_word_count=('response_word_count', 'mean'),\n",
    "    pct_medical_terms=('has_medical_terms', 'mean'),\n",
    "    pct_empathy_words=('has_empathy_words', 'mean')\n",
    ").round(3)\n",
    "\n",
    "print(\"Health Response Quality by Difficulty:\")\n",
    "print(difficulty_analysis.to_string())\n",
    "\n",
    "# Visualization\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Score by difficulty\n",
    "diff_order = ['low', 'medium', 'high']\n",
    "for metric, color in [('humanity_score', '#e74c3c'), ('performance_score', '#3498db'), ('helpfulness_score', '#2ecc71')]:\n",
    "    scores = [health_df[health_df['difficulty'] == d][metric].mean() for d in diff_order]\n",
    "    axes[0].plot(diff_order, scores, 'o-', label=metric.replace('_', ' ').title(), color=color, linewidth=2, markersize=8)\n",
    "\n",
    "axes[0].set_title('Quality Scores by Difficulty', fontsize=12, fontweight='bold')\n",
    "axes[0].set_xlabel('Difficulty Level')\n",
    "axes[0].set_ylabel('Average Score')\n",
    "axes[0].legend(loc='best')\n",
    "axes[0].set_ylim(3, 5)\n",
    "\n",
    "# Word count by difficulty\n",
    "word_counts = [health_df[health_df['difficulty'] == d]['response_word_count'].mean() for d in diff_order]\n",
    "bars = axes[1].bar(diff_order, word_counts, color=['#27ae60', '#f39c12', '#e74c3c'], alpha=0.85, edgecolor='white')\n",
    "for bar, wc in zip(bars, word_counts):\n",
    "    axes[1].text(bar.get_x() + bar.get_width()/2, bar.get_height() + 2,\n",
    "                 f'{wc:.0f}', ha='center', fontweight='bold')\n",
    "axes[1].set_title('Avg Word Count by Difficulty', fontsize=12, fontweight='bold')\n",
    "axes[1].set_xlabel('Difficulty Level')\n",
    "axes[1].set_ylabel('Word Count')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/eda_health_difficulty.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
