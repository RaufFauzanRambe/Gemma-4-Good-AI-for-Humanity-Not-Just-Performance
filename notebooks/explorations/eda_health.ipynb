    "---\n",
    "## 8. Cross-Category Health Insights <a name=\"cross-category\"></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# Cell 9: Radar Chart - Health vs All Categories\n",
    "# ============================================\n",
    "categories_list = sorted(merged_df['category'].unique())\n",
    "score_dims = ['humanity_score', 'performance_score', 'helpfulness_score']\n",
    "if 'safety_score' in merged_df.columns:\n",
    "    score_dims.append('safety_score')\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 10), subplot_kw=dict(polar=True))\n",
    "\n",
    "angles = np.linspace(0, 2 * np.pi, len(score_dims), endpoint=False).tolist()\n",
    "angles += angles[:1]\n",
    "\n",
    "colors = plt.cm.Set2(np.linspace(0, 1, len(categories_list)))\n",
    "\n",
    "for idx, cat in enumerate(categories_list):\n",
    "    cat_data = merged_df[merged_df['category'] == cat]\n",
    "    values = [cat_data[dim].mean() for dim in score_dims]\n",
    "    values += values[:1]\n",
    "    ax.plot(angles, values, 'o-', linewidth=2, label=cat.replace('_', ' ').title(), color=colors[idx])\n",
    "    ax.fill(angles, values, alpha=0.1, color=colors[idx])\n",
    "\n",
    "ax.set_xticks(angles[:-1])\n",
    "ax.set_xticklabels([d.replace('_', ' ').title() for d in score_dims], fontsize=11)\n",
    "ax.set_ylim(0, 5)\n",
    "ax.set_title('Multi-Dimensional Score Comparison by Category', fontsize=14, fontweight='bold', pad=30)\n",
    "ax.legend(loc='upper right', bbox_to_anchor=(1.3, 1.1), fontsize=9)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/eda_health_radar.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
